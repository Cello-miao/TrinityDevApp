# Database Configuration
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=trinityshop
DB_PORT=5432

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Server Port
PORT=3000

# Runtime environment
NODE_ENV=development

# Production security settings
# Comma-separated origins, e.g. https://app.example.com,https://admin.example.com
CORS_ORIGINS=
# Keep false in production; true is for temporary debugging only
ALLOW_INSECURE_HTTP=false

# PayPal Sandbox (get credentials from https://developer.paypal.com)
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret

# Optional: single DATABASE_URL instead of separate DB_* entries
# DATABASE_URL=postgres://user:password@localhost:5432/trinitydb

# If you run with docker-compose, prefer root .env (project/.env) for shared values.
