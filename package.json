{
  "name": "trinity-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "backend": "npm --prefix backend run start",
    "backend:dev": "npm --prefix backend run dev",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f backend db",
    "docker:test": "docker compose --profile test run --rm --no-deps tests",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --runInBand",
    "test:frontend": "jest --selectProjects frontend --runInBand",
    "test:backend": "npm --prefix backend ci --no-audit --no-fund && jest --selectProjects backend --runInBand",
    "test:frontend:coverage": "jest --selectProjects frontend --coverage --runInBand",
    "test:backend:coverage": "npm --prefix backend ci --no-audit --no-fund && jest --selectProjects backend --coverage --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@paypal/react-paypal-js": "^9.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-camera": "~17.0.10",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.8",
    "expo-linking": "~8.0.11",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "jest": "^30.2.0",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@jest/reporters": {
      "glob": "^13.0.0"
    },
    "test-exclude": {
      "glob": "^7.2.3"
    }
  },
  "private": true
}
